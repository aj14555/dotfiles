#!/bin/bash
# Regenerate ~/.config/yazi/theme.toml from the active theme colors.
# Runs automatically after every theme change.

COLORS="$HOME/.config/desktop/current/theme/colors.toml"

c() { grep "^$1 " "$COLORS" | grep -o '"[^"]*"' | tr -d '"'; }

fg=$(c foreground)
bg=$(c background)
accent=$(c accent)
sel_fg=$(c selection_foreground)
sel_bg=$(c selection_background)
red=$(c color1)
blue=$(c color2)
yellow=$(c color3)
purple=$(c color5)
cyan=$(c color6)
dim=$(c color8)

mkdir -p "$HOME/.config/yazi"

cat > "$HOME/.config/yazi/theme.toml" << TOML
# Auto-generated by sys theme-set hook — do not edit manually.
# Re-run: sys theme set "\$(sys theme current)"

[manager]
cwd = { fg = "$cyan" }

hovered         = { fg = "$sel_fg", bg = "$sel_bg", bold = true }
preview_hovered = { underline = true }

find_keyword  = { fg = "$yellow", bold = true, italic = true }
find_position = { fg = "$purple", bg = "reset", italic = true }

marker_copied   = { fg = "$blue",   bg = "$blue" }
marker_cut      = { fg = "$red",    bg = "$red" }
marker_marked   = { fg = "$purple", bg = "$purple" }
marker_selected = { fg = "$accent", bg = "$accent" }

tab_active   = { fg = "$fg",  bg = "$bg", bold = true }
tab_inactive = { fg = "$dim" }

count_copied   = { fg = "$bg", bg = "$blue" }
count_cut      = { fg = "$bg", bg = "$red" }
count_selected = { fg = "$bg", bg = "$accent" }

border_symbol = "│"
border_style  = { fg = "$dim" }

highlight = { bg = "$sel_bg" }

[status]
separator_open  = ""
separator_close = ""
separator_style = { fg = "$dim", bg = "$bg" }

mode_normal = { fg = "$bg", bg = "$accent", bold = true }
mode_select = { fg = "$bg", bg = "$yellow", bold = true }
mode_unset  = { fg = "$bg", bg = "$red",    bold = true }

progress_label  = { bold = true }
progress_normal = { fg = "$accent", bg = "$dim" }
progress_error  = { fg = "$red",    bg = "$dim" }

permissions_t = { fg = "$blue" }
permissions_r = { fg = "$yellow" }
permissions_w = { fg = "$red" }
permissions_x = { fg = "$cyan" }
permissions_s = { fg = "$dim" }

[input]
border   = { fg = "$accent" }
title    = {}
value    = {}
selected = { reversed = true }

[completion]
border   = { fg = "$accent" }
active   = { bg = "$sel_bg" }
inactive = {}

[tasks]
border  = { fg = "$accent" }
title   = {}
hovered = { underline = true }

[which]
mask            = { bg = "$bg" }
cand            = { fg = "$cyan" }
rest            = { fg = "$dim" }
desc            = { fg = "$accent" }
separator       = "  "
separator_style = { fg = "$dim" }

[notify]
title_info  = { fg = "$blue" }
title_warn  = { fg = "$yellow" }
title_error = { fg = "$red" }

icon_info  = "󰋽"
icon_warn  = "󰀦"
icon_error = "󰅚"

[help]
on      = { fg = "$cyan" }
exec    = { fg = "$accent" }
desc    = { fg = "$dim" }
hovered = { bg = "$sel_bg", bold = true }
footer  = { fg = "$bg", bg = "$accent" }

[filetype]
rules = [
  { mime = "image/*",                      fg = "$cyan" },
  { mime = "video/*",                      fg = "$yellow" },
  { mime = "audio/*",                      fg = "$yellow" },
  { mime = "application/zip",              fg = "$red" },
  { mime = "application/gzip",             fg = "$red" },
  { mime = "application/x-tar",            fg = "$red" },
  { mime = "application/x-bzip2",          fg = "$red" },
  { mime = "application/x-7z-compressed",  fg = "$red" },
  { mime = "application/x-rar",            fg = "$red" },
  { mime = "inode/directory",              fg = "$blue" },
  { mime = "inode/symlink",                fg = "$cyan" },
  { mime = "inode/x-empty",               fg = "$dim" },
  { url = "**/.*",                          fg = "$dim" },
]
TOML
